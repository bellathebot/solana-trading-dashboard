# Solana Trading Dashboard Configuration
# Copy this to .env and fill in your values

# Wallet address to track
WALLET_ADDRESS=

# Helius API key (get from https://dev.helius.xyz)
HELIUS_API_KEY=

# Jupiter API key (optional, for higher rate limits — get from https://portal.jup.ag)
JUPITER_API_KEY=

# Path to jup CLI binary (run `which jup` to find it)
JUP_BIN=jup

# Path to helius CLI binary (run `which helius` to find it)
HELIUS_BIN=helius

# Data directory for snapshots and history
DATA_DIR=./data

# Initial deposit value in USD (for all-time PNL calculation)
INITIAL_DEPOSIT_USD=0

# Initial deposit in SOL
INITIAL_DEPOSIT_SOL=0

# Refresh interval in seconds for --watch mode
REFRESH_INTERVAL=60
